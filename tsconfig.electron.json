{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "ignoreDeprecations": "6.0",
    "outDir": "dist/electron",
    "rootDir": "src",
    "noEmit": false,
    "sourceMap": true,
    "declaration": true
  },
  "include": ["src/main/**/*.ts", "src/preload/**/*.ts", "src/worker/**/*.ts", "src/shared/**/*.ts"]
}
