{
  "name": "electron-mini-program",
  "version": "1.0.0",
  "main": "dist/electron/main/index.js",
  "types": "dist/electron/main/container.d.ts",
  "exports": {
    ".": {
      "types": "./dist/electron/main/container.d.ts",
      "require": "./dist/electron/main/container.js",
      "default": "./dist/electron/main/container.js"
    },
    "./app": {
      "types": "./dist/electron/main/index.d.ts",
      "require": "./dist/electron/main/index.js",
      "default": "./dist/electron/main/index.js"
    }
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:renderer": "vite build",
    "build": "npm run clean && npm run build:electron && npm run build:renderer",
    "dev": "npm run build && electron .",
    "start": "npm run build && electron .",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "acorn": "^8.16.0",
    "electron": "^42.3.0",
    "htmlparser2": "^12.0.0",
    "lucide": "^1.17.0",
    "postcss": "^8.5.15"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  }
}
