<view class="container">
  <page-header title="{{motto}}" subtitle="{{subtitle}}" />

  <my-counter count="{{count}}" label="current count" bind:increment="onIncrement" bind:decrement="onDecrement" bind:reset="onReset" />

  <view class="card">
    <text class="card-title">System Info</text>
    <view class="info-row">
      <text class="info-label">Platform</text>
      <text class="info-value">{{platform}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">Version</text>
      <text class="info-value">{{version}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">Clicks</text>
      <text class="info-value">{{clickCount}}</text>
    </view>
  </view>

  <view class="card">
    <text class="card-title">Notification</text>
    <view class="btn-group">
      <view class="btn btn-warning" bindtap="showNotification">Send Notification</view>
    </view>
  </view>

  <view class="card">
    <text class="card-title">File Chooser</text>
    <view class="btn-group">
      <view class="btn btn-info" bindtap="chooseFile">Select File</view>
    </view>
    <view class="info-row" wx:if="{{selectedFile}}">
      <text class="info-label">Selected</text>
      <text class="info-value">{{selectedFile}}</text>
    </view>
  </view>

  <view class="nav-btn" bindtap="goToDetail">Go to Detail Page</view>

  <view class="footer">
    <text class="footer-text">Dual-Thread Mini Program Container v1.0</text>
  </view>
</view>
