<view class="container">
  <view class="header">
    <text class="title">{{motto}}</text>
    <text class="subtitle">{{subtitle}}</text>
  </view>

  <view class="card">
    <text class="card-title">Counter Demo</text>
    <view class="counter-display">
      <text class="counter-number">{{count}}</text>
      <text class="counter-label">current count</text>
    </view>
    <view class="btn-group">
      <view class="btn btn-danger" bindtap="decrement">-1</view>
      <view class="btn btn-primary" bindtap="increment">+1</view>
    </view>
    <view class="btn-group">
      <view class="btn btn-success" bindtap="reset">Reset</view>
    </view>
  </view>

  <view class="card">
    <text class="card-title">System Info</text>
    <view class="info-row">
      <text class="info-label">Platform</text>
      <text class="info-value">{{platform}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">Version</text>
      <text class="info-value">{{version}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">Clicks</text>
      <text class="info-value">{{clickCount}}</text>
    </view>
  </view>

  <view class="nav-btn" bindtap="goToDetail">Go to Detail Page</view>

  <view class="footer">
    <text class="footer-text">Dual-Thread Mini Program Container v1.0</text>
  </view>
</view>
