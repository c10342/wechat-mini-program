.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20px;
  min-height: 100vh;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.header {
  width: 100%;
  padding: 20px 0;
  text-align: center;
}

.title {
  font-size: 24px;
  font-weight: bold;
  color: #ffffff;
  display: block;
}

.subtitle {
  font-size: 14px;
  color: rgba(255, 255, 255, 0.8);
  display: block;
  margin-top: 8px;
}

.card {
  width: 100%;
  background: #ffffff;
  border-radius: 12px;
  padding: 20px;
  margin-top: 16px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.1);
}

.card-title {
  font-size: 18px;
  font-weight: 600;
  color: #333333;
  display: block;
  margin-bottom: 12px;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 10px 0;
  border-bottom: 1px solid #f0f0f0;
}

.info-label {
  font-size: 14px;
  color: #999;
}

.info-value {
  font-size: 14px;
  color: #333;
  font-weight: 500;
}

.back-btn {
  width: 100%;
  margin-top: 20px;
  padding: 14px;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 8px;
  color: #ffffff;
  font-size: 16px;
  text-align: center;
}

.feature-item {
  display: flex;
  align-items: center;
  padding: 10px 0;
  border-bottom: 1px solid #f0f0f0;
}

.feature-index {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: #f093fb;
  color: #fff;
  font-size: 13px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.feature-name {
  font-size: 15px;
  font-weight: 600;
  color: #333;
  margin-left: 12px;
}

.feature-desc {
  font-size: 13px;
  color: #999;
  margin-left: auto;
}

.todo-item {
  padding: 10px 12px;
  background: #f9f9f9;
  border-radius: 6px;
  margin-bottom: 8px;
}

.todo-text {
  font-size: 14px;
  color: #333;
}

.empty-hint {
  font-size: 13px;
  color: #ccc;
  text-align: center;
  padding: 12px 0;
}

.status-block {
  padding: 4px 0;
}

.status-item {
  padding: 12px 16px;
  border-radius: 8px;
  font-size: 15px;
  font-weight: 600;
  text-align: center;
}

.status-low {
  background: #f0f0f0;
  color: #999;
}

.status-med {
  background: #e8f5e9;
  color: #43a047;
}

.status-high {
  background: linear-gradient(135deg, #f093fb, #f5576c);
  color: #fff;
}
