<view class="container">
  <view class="header">
    <text class="title">Detail Page</text>
    <text class="subtitle">This is a second page</text>
  </view>

  <view class="card">
    <text class="card-title">Page Info</text>
    <view class="info-row">
      <text class="info-label">From</text>
      <text class="info-value">{{from}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">Home Count</text>
      <text class="info-value">{{homeCount}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">Visits</text>
      <text class="info-value">{{visitCount}}</text>
    </view>
  </view>

  <view class="card">
    <text class="card-title">Feature List (wx:for)</text>
    <view class="feature-item" wx:for="{{features}}">
      <text class="feature-index">{{index}}</text>
      <text class="feature-name">{{item.name}}</text>
      <text class="feature-desc">{{item.desc}}</text>
    </view>
  </view>

  <view class="card">
    <text class="card-title">Todo List (wx:for + wx:for-item)</text>
    <view class="todo-item" wx:for="{{todos}}" wx:for-item="todo" wx:for-index="idx">
      <text class="todo-text">{{idx + 1}}. {{todo}}</text>
    </view>
    <view class="empty-hint" wx:if="{{todos.length === 0}}">No todos</view>
  </view>

  <view class="card">
    <text class="card-title">Visit Status (wx:if / wx:elif / wx:else)</text>
    <view class="status-block">
      <view class="status-item status-low" wx:if="{{visitCount === 0}}">Newcomer - No visits yet</view>
      <view class="status-item status-med" wx:elif="{{visitCount < 5}}">Regular - {{visitCount}} visits</view>
      <view class="status-item status-high" wx:else>VIP - {{visitCount}} visits!</view>
    </view>
  </view>

  <view class="card">
    <text class="card-title">Actions</text>
    <view class="btn-group" style="margin-top: 12px;">
      <view class="btn btn-primary" bindtap="addVisit">Add Visit</view>
      <view class="btn btn-success" bindtap="addTodo">Add Todo</view>
    </view>
  </view>

  <view class="back-btn" bindtap="goBack">Back to Home</view>
</view>
