.counter-card {
  width: 100%;
  background: #ffffff;
  border-radius: 12px;
  padding: 20px;
  margin-bottom: 16px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.1);
}

.counter-card .card-title {
  font-size: 18px;
  font-weight: 600;
  color: #333333;
  display: block;
  margin-bottom: 12px;
}

.counter-display {
  text-align: center;
  padding: 20px 0;
}

.counter-number {
  font-size: 64px;
  font-weight: bold;
  color: #667eea;
  display: block;
}

.counter-label {
  font-size: 14px;
  color: #999999;
  display: block;
  margin-top: 4px;
}

.btn-group {
  display: flex;
  justify-content: center;
  gap: 12px;
  margin-top: 16px;
}

.btn {
  display: inline-block;
  padding: 12px 32px;
  border-radius: 8px;
  font-size: 16px;
  font-weight: 500;
  text-align: center;
  color: #ffffff;
  cursor: pointer;
}

.btn-primary {
  background: #667eea;
}

.btn-danger {
  background: #f56c6c;
}

.btn-success {
  background: #67c23a;
}
