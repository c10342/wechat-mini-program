<view class="counter-card">
  <text class="card-title">Counter Demo</text>
  <view class="counter-display">
    <text class="counter-number">{{count}}</text>
    <text class="counter-label">{{internalLabel}}</text>
  </view>
  <view class="btn-group">
    <view class="btn btn-danger" bindtap="onDecrement">-1</view>
    <view class="btn btn-primary" bindtap="onIncrement">+1</view>
  </view>
  <view class="btn-group">
    <view class="btn btn-success" bindtap="onReset">Reset</view>
  </view>
</view>
